#: ../../source/pyrepl.md:383
msgid ""
"`runtime.selfref.guide()`: return namespace overview and fork/memory "
"best-practice checklist."
msgstr ""

#: ../../source/pyrepl.md:384
msgid "`runtime.selfref.history.keys()`: list all bound memory keys."
msgstr ""

#: ../../source/pyrepl.md:385
msgid ""
"`runtime.selfref.history.active_key()`: resolve active key for current "
"execution context."
msgstr ""

#: ../../source/pyrepl.md:386
msgid "`runtime.selfref.history.count(key=None)`: return current message count."
msgstr ""

#: ../../source/pyrepl.md:387
msgid ""
"`runtime.selfref.history.all(key=None)`: return a deep-copied snapshot of"
" all messages."
msgstr ""

#: ../../source/pyrepl.md:388
msgid "`runtime.selfref.history.get(index, key=None)`: read one message by index."
msgstr ""

#: ../../source/pyrepl.md:389
msgid ""
"`runtime.selfref.history.append(message, key=None)`: append one message "
"to the tail."
msgstr ""

#: ../../source/pyrepl.md:390
msgid ""
"`runtime.selfref.history.insert(index, message, key=None)`: insert one "
"message at index."
msgstr ""

#: ../../source/pyrepl.md:391
msgid ""
"`runtime.selfref.history.update(index, message, key=None)`: replace one "
"message at index."
msgstr ""

#: ../../source/pyrepl.md:392
msgid ""
"`runtime.selfref.history.delete(index, key=None)`: remove one message by "
"index."
msgstr ""

#: ../../source/pyrepl.md:393
msgid ""
"`runtime.selfref.history.replace(messages, key=None)`: replace full "
"history with a validated list."
msgstr ""

#: ../../source/pyrepl.md:394
msgid ""
"`runtime.selfref.history.clear(key=None)`: clear non-system messages and "
"keep current system prompt."
msgstr ""

#: ../../source/pyrepl.md:395
msgid ""
"`runtime.selfref.history.get_system_prompt(key=None)`: read the latest "
"system prompt text."
msgstr ""

#: ../../source/pyrepl.md:396
msgid ""
"`runtime.selfref.history.set_system_prompt(text, key=None)`: overwrite "
"current system prompt."
msgstr ""

#: ../../source/pyrepl.md:397
msgid ""
"`runtime.selfref.history.append_system_prompt(text, key=None)`: append "
"text to system prompt."
msgstr ""

#: ../../source/pyrepl.md:398
msgid ""
"`runtime.selfref.fork.run(..., include_history=False)`: run one child "
"self-fork and wait for result."
msgstr ""

#: ../../source/pyrepl.md:399
msgid ""
"`runtime.selfref.fork.spawn(...)`: spawn one child self-fork "
"asynchronously."
msgstr ""

#: ../../source/pyrepl.md:400
msgid ""
"`runtime.selfref.fork.wait(fork_id, include_history=False)`: wait for one"
" spawned self-fork result."
msgstr ""

#: ../../source/pyrepl.md:401
msgid ""
"`runtime.selfref.fork.wait_all([fork_id, ...], include_history=False)`: "
"wait for multiple self-fork results, returning `dict[fork_id -> "
"ForkResult]` (iterate with `.items()`/`.values()`)."
msgstr ""

#: ../../source/pyrepl.md:403
msgid ""
"By default, fork results are compact and return metadata like `fork_id`, "
"`memory_key`, `response`, `history_count`, and `history_included=False`. "
"Set `include_history=True` only when you truly need full child message "
"history."
msgstr ""

