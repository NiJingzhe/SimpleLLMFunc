#: ../../source/tui.md:1
msgid "终端 TUI（Textual）"
msgstr "终端 TUI（Textual）"

#: ../../source/tui.md:3
msgid "SimpleLLMFunc 提供了开箱即用的 TUI 装饰器，基于 `textual` + `event stream` 构建。"
msgstr "SimpleLLMFunc 提供了开箱即用的 TUI 装饰器，基于 `textual` + `event stream` 构建。"

#: ../../source/tui.md:5
msgid "你可以把它直接叠加在 `@llm_chat` 上，让 Agent 具备完整的终端输入循环、流式渲染和工具调用可视化。"
msgstr "你可以把它直接叠加在 `@llm_chat` 上，让 Agent 具备完整的终端输入循环、流式渲染和工具调用可视化。"

#: ../../source/tui.md:7
msgid "安装依赖"
msgstr "安装依赖"

#: ../../source/tui.md:9
msgid "`textual` 已作为框架依赖。"
msgstr "`textual` 已作为框架依赖。"

#: ../../source/tui.md:11
msgid "如果你在已有环境中升级，请重新安装依赖："
msgstr "如果你在已有环境中升级，请重新安装依赖："

#: ../../source/tui.md:17
msgid "快速开始"
msgstr "快速开始"

#: ../../source/tui.md:38
msgid "UI 能力"
msgstr "UI 能力"

#: ../../source/tui.md:40
msgid "用户消息与模型消息交替渲染"
msgstr "用户消息与模型消息交替渲染"

#: ../../source/tui.md:41
msgid "模型流式输出实时刷新，并支持 Markdown 渲染"
msgstr "模型流式输出实时刷新，并支持 Markdown 渲染"

#: ../../source/tui.md:42
msgid "推理增量（reasoning delta）以灰色文本展示（当模型提供该字段时）"
msgstr "推理增量（reasoning delta）以灰色文本展示（当模型提供该字段时）"

#: ../../source/tui.md:43
msgid "每次模型调用结束后，在消息下方展示耗时与 token 用量"
msgstr "每次模型调用结束后，在消息下方展示耗时与 token 用量"

#: ../../source/tui.md:44
msgid "工具调用开始时展示结构化参数（可读格式，不是裸 JSON 字符串）"
msgstr "工具调用开始时展示结构化参数（可读格式，不是裸 JSON 字符串）"

#: ../../source/tui.md:45
msgid "工具执行期间消费 `CustomEvent` 并实时更新工具输出"
msgstr "工具执行期间消费 `CustomEvent` 并实时更新工具输出"

#: ../../source/tui.md:46
msgid "工具结束后展示结果与调用统计（耗时/状态）"
msgstr "工具结束后展示结果与调用统计（耗时/状态）"

#: ../../source/tui.md:47
msgid "聊天消息区支持超出视口滚动，单条消息有最大高度并支持内部滚动"
msgstr "聊天消息区支持超出视口滚动，单条消息有最大高度并支持内部滚动"

#: ../../source/tui.md:49
msgid "交互与退出"
msgstr "交互与退出"

#: ../../source/tui.md:51
msgid "发送消息：输入后按 Enter"
msgstr "发送消息：输入后按 Enter"

#: ../../source/tui.md:52
msgid "退出命令：`/exit`、`/quit`、`/q`"
msgstr "退出命令：`/exit`、`/quit`、`/q`"

#: ../../source/tui.md:53
msgid "快捷键退出：`Ctrl+Q`（同时保留 `Ctrl+C`）"
msgstr "快捷键退出：`Ctrl+Q`（同时保留 `Ctrl+C`）"

#: ../../source/tui.md:55
msgid "自定义 Tool 事件 Hook"
msgstr "自定义 Tool 事件 Hook"

#: ../../source/tui.md:57
msgid "`@tui` 支持通过 `custom_event_hook` 注入自定义事件解析逻辑："
msgstr "`@tui` 支持通过 `custom_event_hook` 注入自定义事件解析逻辑："

#: ../../source/tui.md:82
msgid "框架也内置了部分常见工具事件的默认解析（例如 PyRepl 的 `kernel_stdout`/`kernel_stderr`）。"
msgstr "框架也内置了部分常见工具事件的默认解析（例如 PyRepl 的 `kernel_stdout`/`kernel_stderr`）。"

