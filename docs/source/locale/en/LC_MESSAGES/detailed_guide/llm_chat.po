#: ../../source/detailed_guide/llm_chat.md:381
msgid "Forgetting memory:"
msgstr "Forgetting memory:"

#: ../../source/detailed_guide/llm_chat.md:383
msgid "Do not treat `reset_repl` as memory forgetting."
msgstr "Do not treat `reset_repl` as memory forgetting."

#: ../../source/detailed_guide/llm_chat.md:384
msgid "`reset_repl` only clears Python runtime variables."
msgstr "`reset_repl` only clears Python runtime variables."

#: ../../source/detailed_guide/llm_chat.md:385
msgid ""
"Forget memory by deleting/replacing records through selfref history "
"primitives (`runtime.selfref.history.delete`, "
"`runtime.selfref.history.replace`); `runtime.selfref.history.clear` keeps "
"only the current system prompt."
msgstr ""
"Forget memory by deleting/replacing records through selfref history "
"primitives (`runtime.selfref.history.delete`, "
"`runtime.selfref.history.replace`); `runtime.selfref.history.clear` keeps "
"only the current system prompt."

