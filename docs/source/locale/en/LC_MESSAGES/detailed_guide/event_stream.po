#: ../../source/detailed_guide/event_stream.md:188
msgid "EventYield"
msgstr "EventYield"

#: ../../source/detailed_guide/event_stream.md:190
msgid "事件数据，包含 ReAct 循环中的各种事件："
msgstr "Event data, containing various events in the ReAct loop:"

#: ../../source/detailed_guide/event_stream.md:200
msgid "EventOrigin（来源元数据）"
msgstr "EventOrigin (source metadata)"

#: ../../source/detailed_guide/event_stream.md:202
msgid "`EventOrigin` 用于描述事件在调用树中的来源。常用字段如下："
msgstr ""
"`EventOrigin` is used to describe the origin of events in the call tree. "
"Common fields are as follows:"

#: ../../source/detailed_guide/event_stream.md:204
msgid "`session_id`: 当前会话 ID（同一会话内稳定）"
msgstr "`session_id`: current session ID (stable within the same session)"

#: ../../source/detailed_guide/event_stream.md:205
msgid "`agent_call_id`: 当前 agent 调用 ID"
msgstr "`agent_call_id`: current agent call ID"

#: ../../source/detailed_guide/event_stream.md:206
msgid "`parent_agent_call_id`: 父 agent 调用 ID（如果存在）"
msgstr "`parent_agent_call_id`: parent agent call ID (if it exists)"

#: ../../source/detailed_guide/event_stream.md:207
msgid "`event_seq`: 会话内递增事件序号"
msgstr "`event_seq`: incremental event sequence number within a session"

#: ../../source/detailed_guide/event_stream.md:208
msgid "`fork_id`: fork 场景下的分叉 ID（主会话通常为 `None`）"
msgstr "`fork_id`: fork ID in fork scenario (main session is usually `None`)"

#: ../../source/detailed_guide/event_stream.md:209
msgid "`fork_depth`: 分叉深度（主会话通常为 `0`）"
msgstr "`fork_depth`: Fork depth (main session is usually `0`)"

#: ../../source/detailed_guide/event_stream.md:210
msgid "`fork_seq`: fork 内事件序号（若存在）"
msgstr "`fork_seq`: event sequence number within fork (if exists)"

#: ../../source/detailed_guide/event_stream.md:211
msgid "`selfref_instance_id`: SelfReference 实例标识（若存在）"
msgstr "`selfref_instance_id`: SelfReference instance identifier (if exists)"

#: ../../source/detailed_guide/event_stream.md:212
msgid "`memory_key` / `source_memory_key`: selfref 记忆键上下文"
msgstr "`memory_key` / `source_memory_key`: selfref memory key context"

#: ../../source/detailed_guide/event_stream.md:213
msgid "`tool_name` / `tool_call_id`: 工具事件关联信息"
msgstr "`tool_name` / `tool_call_id`: tool event correlation information"

#: ../../source/detailed_guide/event_stream.md:215
msgid "快速示例："
msgstr "Quick Example:"

#: ../../source/detailed_guide/event_stream.md:233
msgid "事件类型"
msgstr "Event type"

#: ../../source/detailed_guide/event_stream.md:235
msgid "事件流包含以下类型的事件，按执行顺序排列："
msgstr ""
"The event stream contains the following event types, in execution order:"

#: ../../source/detailed_guide/event_stream.md:237
msgid "1. ReactStartEvent"
msgstr "1. ReactStartEvent"

#: ../../source/detailed_guide/event_stream.md:239
msgid "ReAct 循环开始事件，在循环开始时触发。"
msgstr "ReAct loop start event, triggered at the beginning of the loop."

#: ../../source/detailed_guide/event_stream.md:249
msgid "**使用场景**：初始化 UI、显示开始提示、记录 trace_id"
msgstr ""
"**Usage Scenarios**: Initialize UI, display start prompt, record trace_id"

#: ../../source/detailed_guide/event_stream.md:251
msgid "2. ReactIterationStartEvent"
msgstr "2. ReactIterationStartEvent"

#: ../../source/detailed_guide/event_stream.md:253
msgid "ReAct 迭代开始事件，每次迭代开始时触发。"
msgstr ""
"ReAct iteration start event, triggered at the start of each iteration."

#: ../../source/detailed_guide/event_stream.md:261
msgid "**使用场景**：显示迭代进度、更新消息历史"
msgstr "**Use case**: Display iteration progress, update message history"

#: ../../source/detailed_guide/event_stream.md:263
msgid "3. LLMCallStartEvent"
msgstr "3. LLMCallStartEvent"

#: ../../source/detailed_guide/event_stream.md:265
msgid "LLM 调用开始事件，在 LLM 调用前触发。"
msgstr "LLM call start event, triggered before the LLM call."

#: ../../source/detailed_guide/event_stream.md:276
msgid "**使用场景**：显示\"正在思考...\"提示、记录调用参数"
msgstr ""
"**Use Case**: Display \"Thinking...\" prompt, record invocation parameters"

#: ../../source/detailed_guide/event_stream.md:278
msgid "4. LLMChunkArriveEvent"
msgstr "4. LLMChunkArriveEvent"

#: ../../source/detailed_guide/event_stream.md:280
msgid "LLM 流式 chunk 到达事件（仅流式模式）。"
msgstr "LLM streaming chunk arrival event (streaming mode only)."

#: ../../source/detailed_guide/event_stream.md:290
msgid "**使用场景**：实时渲染流式响应、显示打字效果"
msgstr ""
"**Use cases**: Real-time rendering of streaming responses, displaying typing"
" effects"

#: ../../source/detailed_guide/event_stream.md:292
msgid "5. LLMCallEndEvent"
msgstr "5. LLMCallEndEvent"

#: ../../source/detailed_guide/event_stream.md:294
msgid "LLM 调用结束事件，在调用完成后触发。"
msgstr "LLM call end event, triggered after the call is completed."

#: ../../source/detailed_guide/event_stream.md:306
msgid "**使用场景**：显示 Token 使用量、记录性能指标、检查工具调用"
msgstr ""
"**Usage Scenarios**: Display token usage, record performance metrics, check "
"tool calls"

#: ../../source/detailed_guide/event_stream.md:308
msgid "6. ToolCallsBatchStartEvent"
msgstr "6. ToolCallsBatchStartEvent"

#: ../../source/detailed_guide/event_stream.md:310
msgid "工具调用批次开始事件，当 LLM 返回多个工具调用时触发。"
msgstr ""
"Tool call batch start event, triggered when LLM returns multiple tool calls."

#: ../../source/detailed_guide/event_stream.md:319
msgid "**使用场景**：显示工具调用批次信息、准备并行执行"
msgstr ""
"**Use Cases**: Display tool invocation batch information, prepare for "
"parallel execution"

#: ../../source/detailed_guide/event_stream.md:321
msgid "7. ToolCallStartEvent"
msgstr "7. ToolCallStartEvent"

#: ../../source/detailed_guide/event_stream.md:323
msgid "单个工具调用开始事件。"
msgstr "Single tool call start event."

#: ../../source/detailed_guide/event_stream.md:334
msgid "**使用场景**：显示工具调用信息、记录调用参数"
msgstr "**Use Case**: Display tool call information, record call parameters"

#: ../../source/detailed_guide/event_stream.md:336
msgid "8. ToolCallArgumentsDeltaEvent"
msgstr "8. ToolCallArgumentsDeltaEvent"

#: ../../source/detailed_guide/event_stream.md:338
msgid "工具调用参数增量事件（仅流式模式）。"
msgstr "Tool Call Parameter Incremental Event (Streaming Mode Only)"

#: ../../source/detailed_guide/event_stream.md:349
msgid "**使用场景**：在工具调用尚未开始前，增量渲染参数拼装过程（适合 TUI 实时面板）。"
msgstr ""
"**Usage Scenario**: Incremental rendering parameter assembly process before "
"the tool call starts (suitable for TUI real-time panels)."

#: ../../source/detailed_guide/event_stream.md:351
msgid "9. ToolCallEndEvent"
msgstr "9. ToolCallEndEvent"

#: ../../source/detailed_guide/event_stream.md:353
msgid "单个工具调用结束事件（**关键**：立即获取结果）。"
msgstr "Single tool call end event (**critical**: get result immediately)."

#: ../../source/detailed_guide/event_stream.md:366
msgid "**使用场景**：显示工具执行结果、更新 UI、记录执行时间"
msgstr ""
"**Use Case**: Display tool execution results, update UI, record execution "
"time"

#: ../../source/detailed_guide/event_stream.md:368
msgid "10. CustomEvent"
msgstr "10. CustomEvent"

#: ../../source/detailed_guide/event_stream.md:370
msgid "工具内部主动发射的自定义事件，用于进度、日志、阶段状态等实时反馈。"
msgstr ""
"Custom events proactively emitted inside tools for real-time feedback such "
"as progress, logs, and stage status."

#: ../../source/detailed_guide/event_stream.md:381
msgid "**使用场景**：在 TUI 或自定义 UI 中增量渲染工具执行过程（例如 PyRepl stdout/stderr、批处理进度）。"
msgstr ""
"**Use cases**: Incrementally render tool execution progress in a TUI or "
"custom UI (for example, PyRepl stdout/stderr and batch progress)."

#: ../../source/detailed_guide/event_stream.md:383
msgid "11. ToolCallsBatchEndEvent"
msgstr "11. ToolCallsBatchEndEvent"

#: ../../source/detailed_guide/event_stream.md:385
msgid "工具调用批次结束事件，批次全部完成后触发。"
msgstr "Tool call batch end event, triggered after all batches are completed."

#: ../../source/detailed_guide/event_stream.md:397
msgid "**使用场景**：显示批次统计、性能分析"
msgstr "**Use Cases**: Display batch statistics, performance analysis"

#: ../../source/detailed_guide/event_stream.md:399
msgid "12. ReactIterationEndEvent"
msgstr "12. ReactIterationEndEvent"

#: ../../source/detailed_guide/event_stream.md:401
msgid "ReAct 迭代结束事件，每次迭代完成时触发。"
msgstr ""
"ReAct iteration end event, triggered when each iteration is completed."

#: ../../source/detailed_guide/event_stream.md:411
msgid "**使用场景**：显示迭代统计、更新进度"
msgstr "**Usage Scenario**: Display iteration statistics, update progress"

#: ../../source/detailed_guide/event_stream.md:413
msgid "13. ReactEndEvent"
msgstr "13. ReactEndEvent"

#: ../../source/detailed_guide/event_stream.md:415
msgid "ReAct 循环结束事件，循环结束时触发。"
msgstr "ReAct loop end event, triggered when the loop ends."

#: ../../source/detailed_guide/event_stream.md:429
msgid "当通过 `AbortSignal` 中断回合时，`ReactEndEvent.extra` 会附加："
msgstr ""
"When the round is interrupted via `AbortSignal`, `ReactEndEvent.extra` will "
"be attached:"

#: ../../source/detailed_guide/event_stream.md:431
msgid "`aborted: true`"
msgstr "aborted: true"

#: ../../source/detailed_guide/event_stream.md:432
msgid "`abort_reason: <reason>`（如果调用 `abort(reason)` 时提供了 reason）"
msgstr ""
"abort_reason: <reason> (if a reason was provided when calling abort(reason))"

#: ../../source/detailed_guide/event_stream.md:434
msgid "**使用场景**：显示完整统计、性能分析、保存执行记录"
msgstr ""
"**Usage Scenarios**: Display complete statistics, performance analysis, save"
" execution records"

#: ../../source/detailed_guide/event_stream.md:436
msgid "Fork 场景事件路由"
msgstr "Fork Scenario Event Routing"

#: ../../source/detailed_guide/event_stream.md:438
